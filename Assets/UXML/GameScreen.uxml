<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:Template name="Topbar" src="project://database/Assets/UXML/Templates/Topbar.uxml?fileID=9197481963319205126&amp;guid=39ad76582b34a834b91735e6512f8402&amp;type=3#Topbar"/>
    <Style src="project://database/Assets/stylesheet.uss?fileID=7433441132597879392&amp;guid=f6325ce37e11e7b4c8a3e508c4d145c7&amp;type=3#stylesheet"/>
    <ui:VisualElement name="Container" style="flex-grow: 1;">
        <ui:Instance template="Topbar">
            <AttributeOverrides element-name="Setup" text="Game"/>
        </ui:Instance>
        <ui:VisualElement name="GameScreen" style="flex-grow: 1; flex-direction: row;">
            <ui:VisualElement name="MainScreen" style="flex-grow: 1; width: 80%; background-color: rgb(213, 242, 227); padding-top: 60px; padding-right: 60px; padding-bottom: 60px; padding-left: 60px;">
                <ui:VisualElement name="Grid" style="flex-grow: 1;">
                    <ui:VisualElement name="1stRow" style="flex-direction: row;">
                        <ui:VisualElement name="1stRow1" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="1stRow2" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="1stRow3" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="1stRow4" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="1stRow5" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="1stRow6" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="1stRow7" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="1stRow8" class="grid" style="width: 12.5%;"/>
                    </ui:VisualElement>
                    <ui:VisualElement name="2ndRow" style="flex-direction: row;">
                        <ui:VisualElement name="2ndRow1" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="2ndRow2" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="2ndRow3" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="2ndRow4" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="2ndRow5" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="2ndRow6" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="2ndRow7" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="2ndRow8" class="grid" style="width: 12.5%;"/>
                    </ui:VisualElement>
                    <ui:VisualElement name="3rdRow" style="flex-direction: row;">
                        <ui:VisualElement name="3rdRow1" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="3rdRow2" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="3rdRow3" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="3rdRow4" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="3rdRow5" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="3rdRow6" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="3rdRow7" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="3rdRow8" class="grid" style="width: 12.5%;"/>
                    </ui:VisualElement>
                    <ui:VisualElement name="4thRow" style="flex-direction: row;">
                        <ui:VisualElement name="4thRow1" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="4thRow2" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="4thRow3" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="4thRow4" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="4thRow5" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="4thRow6" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="4thRow7" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="4thRow8" class="grid" style="width: 12.5%;"/>
                    </ui:VisualElement>
                    <ui:VisualElement name="5thRow" style="flex-direction: row;">
                        <ui:VisualElement name="5thRow1" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="5thRow2" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="5thRow3" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="5thRow4" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="5thRow5" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="5thRow6" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="5thRow7" class="grid" style="width: 12.5%;"/>
                        <ui:VisualElement name="5thRow8" class="grid" style="width: 12.5%;"/>
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="SideBar" class="side-bar" style="flex-grow: 1;">
                <ui:Label text="Stats" name="SideBarTitle" class="sidebar-title"/>
                <ui:Label text="Name :" name="Name" class="field" style="overflow: visible; padding-top: 10px; padding-right: 10px; padding-bottom: 10px; padding-left: 10px;"/>
                <ui:Label text="Hp :" name="hp" class="field" style="overflow: hidden; padding-top: 10px; padding-right: 10px; padding-bottom: 10px; padding-left: 10px;"/>
                <ui:Label text="Attack :" name="Attack" class="field" style="padding-top: 10px; padding-right: 10px; padding-bottom: 10px; padding-left: 10px;"/>
                <ui:VisualElement name="AddButtons" style="flex-grow: 1; flex-direction: row; justify-content: space-around; translate: 0 0%; align-self: stretch; align-items: flex-end; padding-bottom: 40px;">
                    <ui:Button text="Move" name="MoveButton" class="classic-button"/>
                    <ui:Button text="Attack" name="AttackButton" class="classic-button" style="height: 54px;"/>
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
